# Cloudflare Configuration Example
# Copy this file to .env.local and fill in your values

# Cloudflare API Token (required for deployment)
# Create this at: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Account:Edit, Workers:Edit, Pages:Edit
CLOUDFLARE_API_TOKEN=your_api_token_here

# Cloudflare Account ID (required for deployment)
# Find this in your Cloudflare dashboard URL
CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# Database URL (for API server)
# DATABASE_URL=postgresql://user:password@host:port/database

# Frontend API URL (if API is deployed separately)
# VITE_API_URL=https://brain-battle-hub-api.your-subdomain.workers.dev
